generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model User {
  id            Int            @id @default(autoincrement())
  kakaoId       String         @unique
  nickname      String
  email         String?
  profileImage  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  subscriptions Subscription[]
  fcmTokens     FcmToken[]
  notifications Notification[]
}

model Artist {
  id            Int      @id @default(autoincrement())
  name          String
  nameEn        String?
  aliases       String[] @default([])
  imageUrl      String?
  musicbrainzId String?  @unique
  spotifyId     String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions Subscription[]
  performances  Performance[]
}

model Venue {
  id        Int      @id @default(autoincrement())
  name      String
  kopisId   String   @unique
  address   String?
  lat       Float?
  lng       Float?
  seatScale Int?
  phone     String?
  website   String?
  sido      String?
  gugun     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  performances Performance[]
}

model Performance {
  id             Int              @id @default(autoincrement())
  title          String
  artistId       Int?
  artist         Artist?          @relation(fields: [artistId], references: [id])
  venueId        Int?
  venue          Venue?           @relation(fields: [venueId], references: [id])
  startDate      DateTime?
  endDate        DateTime?
  ticketOpenDate DateTime?
  source         TicketSource
  sourceId       String
  sourceUrl      String
  imageUrl       String?
  rawTitle       String
  kopisId        String?
  genre          PerformanceGenre
  status         PerformanceStatus
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  notifications Notification[]

  @@unique([source, sourceId])
  @@index([kopisId])
}

model Subscription {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  artistId  Int
  artist    Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, artistId])
}

model FcmToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  device    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id            Int              @id @default(autoincrement())
  userId        Int
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  performanceId Int
  performance   Performance      @relation(fields: [performanceId], references: [id])
  type          NotificationType
  sentAt        DateTime         @default(now())
  readAt        DateTime?
}

model SyncLog {
  id           Int         @id @default(autoincrement())
  source       String
  startedAt    DateTime    @default(now())
  completedAt  DateTime?
  itemsFound   Int         @default(0)
  newItems     Int         @default(0)
  updatedItems Int         @default(0)
  errors       String?
  status       SyncStatus  @default(RUNNING)
}

enum TicketSource {
  MELON
  YES24
  INTERPARK
}

enum PerformanceGenre {
  CONCERT
  FESTIVAL
  FANMEETING
  MUSICAL
  CLASSIC
  HIPHOP
  TROT
  OTHER
}

enum PerformanceStatus {
  UPCOMING
  ON_SALE
  SOLD_OUT
  COMPLETED
  CANCELLED
}

enum NotificationType {
  NEW_CONCERT
  TICKET_OPEN_SOON
}

enum SyncStatus {
  RUNNING
  SUCCESS
  FAILED
}
