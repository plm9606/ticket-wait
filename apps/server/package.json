    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/jwt": "^9.0.0",
    "@prisma/client": "^6.4.0",
    "axios": "^1.7.0",
    "cheerio": "^1.0.0",
    "dotenv": "^17.3.1",
    "fast-xml-parser": "^5.5.10",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.1.0",
    "firebase-admin": "^13.7.0",
    "node-cron": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.0",
    "openapi-typescript": "^7.13.0",
    "prisma": "^6.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
